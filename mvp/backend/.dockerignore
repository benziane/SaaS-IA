# Python bytecode
__pycache__/
*.pyc
*.pyo
*.pyd

# Environment & secrets
.env
.env.*
!.env.example

# Version control
.git/
.gitignore

# IDE / editor
.vscode/
.idea/
*.swp
*.swo
*~

# Type-checking & linting caches
.mypy_cache/
.pytest_cache/
.ruff_cache/
.coverage
coverage.*
htmlcov/

# Tests & docs (not needed in image)
tests/
docs/
*.md

# Docker meta (avoid recursive COPY)
Dockerfile*
docker-compose*
.dockerignore
.dockge.yml

# Node / frontend artefacts (if accidentally present)
node_modules/

# Virtual environments
venv/
.venv/

# Logs & temp
*.log
*.sql

# OS files
.DS_Store
Thumbs.db
