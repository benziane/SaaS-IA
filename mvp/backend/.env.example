# ========================================
# SaaS-IA MVP - Configuration
# ========================================

# Application
APP_NAME=SaaS-IA MVP
ENVIRONMENT=development
DEBUG=True

# Database (PostgreSQL)
DATABASE_URL=postgresql://saas_ia_user:saas_ia_dev_password@localhost:5435/saas_ia

# Redis Cache
REDIS_URL=redis://localhost:6382

# Security
SECRET_KEY=change-me-in-production-use-strong-random-key

# JWT
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# AI Providers
ASSEMBLYAI_API_KEY=MOCK
GEMINI_API_KEY=
CLAUDE_API_KEY=
GROQ_API_KEY=

# CORS
CORS_ORIGINS=http://localhost:3002,http://localhost:8004

# Logging
LOG_LEVEL=INFO

# Stripe (optional - for payment processing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
